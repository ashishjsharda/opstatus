# ─── Site Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME="Acme Status"
NEXT_PUBLIC_SITE_URL="https://status.acme.com"
NEXT_PUBLIC_SUPPORT_URL="https://acme.com/support"

# ─── Admin Auth ────────────────────────────────────────────────────────────────
# Change this to a long random secret before deploying!
ADMIN_PASSWORD="change-me-please"
SESSION_SECRET="generate-a-random-32-char-string-here"

# ─── Email (optional) ─────────────────────────────────────────────────────────
# If set, subscriber notifications will be sent automatically.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="status@acme.com"

# ─── Database ──────────────────────────────────────────────────────────────────
# Path to SQLite database file. Defaults to ./data/opstatus.db
DATABASE_PATH="./data/opstatus.db"
